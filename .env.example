# ─────────────────────────────────────────────────────────────
# waagent configuration — copy this file to `.env` and fill in.
# ─────────────────────────────────────────────────────────────

# --- Claude (the agent's brain) ---
# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# Model id. Default is the latest Opus. See README for cheaper options.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Who the agent represents (used in its system prompt) ---
OWNER_NAME=Your Name
BUSINESS_NAME=Your Business
# A short description of what you do — helps the agent answer correctly.
BUSINESS_DESCRIPTION=A legal services firm helping clients with documents and filings.

# --- Reply behaviour ---
# auto  = reply automatically (with the safeguards below)
# off   = receive & log only, never send (use this for a dry run first)
REPLY_MODE=auto

# Comma-separated WhatsApp numbers (digits only, with country code, no +).
# If set, the agent ONLY auto-replies to these contacts (allowlist).
# Leave blank to reply to any 1:1 chat that isn't blocked.
ALLOWLIST=
# Comma-separated numbers the agent must NEVER reply to.
BLOCKLIST=

# Never auto-reply in group chats (recommended: true).
IGNORE_GROUPS=true

# Minimum seconds between auto-replies to the same chat (anti-spam / loop guard).
MIN_REPLY_INTERVAL_SECONDS=2

# Business hours (24h, owner's local time). Outside these the agent sends an
# after-hours holding message instead of a full reply. Leave both blank to be
# always-on.
BUSINESS_HOURS_START=
BUSINESS_HOURS_END=

# --- Google Drive (phase 2 — not active yet) ---
# When you're ready to let the agent send/upload client documents, fill these
# in and set GDRIVE_ENABLED=true. See src/tools/drive.js.
GDRIVE_ENABLED=false
GDRIVE_CREDENTIALS_PATH=./credentials.json
GDRIVE_TOKEN_PATH=./token.json
# Folder in your Drive the agent is allowed to read documents from / upload to.
GDRIVE_FOLDER_ID=
