# ─────────────────────────────────────────────────────────────
# waagent (multi-tenant) — copy to `.env` and fill in.
# ─────────────────────────────────────────────────────────────

# Web server
PORT=3000
NODE_ENV=development
# Set true only when serving over HTTPS (marks the login cookie Secure).
COOKIE_SECURE=false

# --- PostgreSQL ---
# e.g. postgres://waagent:secret@localhost:5432/waagent
# Append ?sslmode=require for most managed providers (Neon, Supabase, RDS).
DATABASE_URL=postgres://waagent:secret@localhost:5432/waagent

# --- Secrets (use long random strings; generate with: openssl rand -hex 32) ---
# Signs login session cookies.
SESSION_SECRET=change-me-to-a-long-random-string
# Encrypts each user's Anthropic API key at rest. Changing it makes already
# stored keys undecryptable (users would re-enter their key).
ENCRYPTION_KEY=change-me-to-a-different-long-random-string

# Where per-user WhatsApp link sessions are stored on disk.
AUTH_ROOT=./auth

# Default Claude model offered to new users (they can change it in settings).
DEFAULT_MODEL=claude-opus-4-8

# NOTE: Users bring their OWN Anthropic API key via the dashboard settings —
# there is no global ANTHROPIC_API_KEY in the multi-tenant build.
